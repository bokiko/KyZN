#!/usr/bin/env bash
# kyzn — Autonomous Code Improvement CLI
# https://github.com/bokiko/kyzn
set -euo pipefail
umask 077

# Require bash 4.3+ for associative arrays and namerefs
if (( BASH_VERSINFO[0] < 4 || (BASH_VERSINFO[0] == 4 && BASH_VERSINFO[1] < 3) )); then
    echo "KyZN requires bash 4.3 or later (you have $BASH_VERSION)." >&2
    if [[ "$(uname)" == "Darwin" ]]; then
        echo "  Install with: brew install bash" >&2
        echo "  Then run: /opt/homebrew/bin/bash $(readlink -f "$0" 2>/dev/null || echo "$0") $*" >&2
    fi
    exit 1
fi

KYZN_VERSION="1.0.0"
# Resolve symlinks portably (readlink -f doesn't exist on macOS)
_kyzn_resolve() {
    local f="$1"
    local max_depth=20
    local depth=0
    while [[ -L "$f" ]]; do
        if (( depth++ >= max_depth )); then echo "KyZN: symlink loop detected resolving $1" >&2; echo "$f"; return 1; fi
        local dir
        dir="$(cd "$(dirname "$f")" && pwd)"
        f="$(readlink "$f")"
        [[ "$f" != /* ]] && f="$dir/$f"
    done
    echo "$f"
}
KYZN_ROOT="$(cd "$(dirname "$(_kyzn_resolve "${BASH_SOURCE[0]}")")" && pwd)"

# Load core library
# shellcheck source=lib/core.sh
source "$KYZN_ROOT/lib/core.sh"

# ---------------------------------------------------------------------------
# Subcommand routing
# ---------------------------------------------------------------------------
usage() {
    cat <<'EOF'
KyZN — Autonomous Code Improvement CLI (kaizen)

Usage:
  kyzn <command> [options]

Commands:
  fix             Deep analysis + auto-fix (analyze → fix → verify → PR)
  analyze         Deep analysis only — report, no changes
  quick           Quick single-pass improvement (lighter, cheaper)
  measure         Measure project health (no changes)
  doctor          Check prerequisites
  init            Interactive setup (creates .kyzn/config.yaml)
  status          Show health score dashboard

  approve <id>    Sign off on a completed improvement
  reject <id>     Reject with reason
  diff <id>       Show what a run changed
  history         Show all runs with scores and trends
  dashboard       Machine-wide activity summary (all projects)

  schedule        Set up recurring runs (cron)
  selftest        Run the test suite
  update          Pull latest version
  version         Show version

Common options:
  --provider <p>      claude | codex | auto (default: claude)
  --auto              Use saved config (no prompts, for cron)

Quick options:
  --focus <area>      Target specific area (security, testing, perf, quality, doc)
  --mode <mode>       deep | clean | full
  --model <model>     sonnet | opus | haiku
  --budget <USD>      Budget per run (e.g. 5.00)
  --turns <N>         Max Claude turns per run
  --allow-ci          Allow CI/pipeline file creation
  -v, --verbose       Show live Claude progress

Fix options:
  --fix-budget <USD>  Budget for fix phase (default: $5)
  --min-severity <s>  Minimum severity to fix (CRITICAL|HIGH|MEDIUM|LOW)
  --profile <p>       opus | hybrid | sonnet
  --budget <USD>      Budget for analysis phase

Analyze options:
  --fix               Auto-fix findings after analysis (same as 'kyzn fix')
  --fix-budget <USD>  Budget for fix phase
  --single            Use single reviewer instead of 4 specialists
  --focus <area>      Narrow analysis to one area
  --profile <p>       opus | hybrid | sonnet

History options:
  --global            Show history from all projects

General:
  -h, --help          Show this help
  -v, --version       Show version

Examples:
  kyzn init                       # First-time setup
  kyzn doctor                     # Check prerequisites
  kyzn fix                        # Deep analysis + auto-fix → PR
  kyzn fix --auto                 # Non-interactive (cron-safe)
  kyzn fix --profile hybrid       # Cheaper analysis model mix
  kyzn analyze                    # Analysis report only, no changes
  kyzn analyze --focus security   # Single-area deep dive
  kyzn quick                      # Quick single-pass improvement
  kyzn quick --auto               # Use saved config (for cron)
  kyzn quick --mode deep          # Real improvements only
  kyzn measure                    # Measure only, no changes
  kyzn history --global           # All projects
EOF
}

# ---------------------------------------------------------------------------
# Update check — notify user if a newer version exists
# ---------------------------------------------------------------------------
check_for_updates() {
    # Check if install dir is a git repo
    [[ -d "$KYZN_ROOT/.git" ]] || return

    # Quick check: is local HEAD behind remote? (fetch once per day)
    local check_file="${HOME}/.kyzn/last-update-check"
    local needs_fetch=true
    mkdir -p "${HOME}/.kyzn"

    if [[ -f "$check_file" ]]; then
        local last_check now
        last_check=$(cat "$check_file" 2>/dev/null || echo 0)
        now=$(date +%s)
        if (( now - last_check < 86400 )); then needs_fetch=false; fi
    fi

    if $needs_fetch; then
        if command -v timeout &>/dev/null; then
            timeout 5 safe_git -C "$KYZN_ROOT" fetch origin --quiet 2>/dev/null || true
        else
            safe_git -C "$KYZN_ROOT" fetch origin --quiet 2>/dev/null || true
        fi
        date +%s > "$check_file" 2>/dev/null || true
    fi

    # Compare local vs remote
    local local_head remote_head
    local_head=$(safe_git -C "$KYZN_ROOT" rev-parse HEAD 2>/dev/null) || return
    remote_head=$(safe_git -C "$KYZN_ROOT" rev-parse origin/main 2>/dev/null) || return

    if [[ "$local_head" != "$remote_head" ]]; then
        local behind
        behind=$(safe_git -C "$KYZN_ROOT" rev-list --count HEAD..origin/main 2>/dev/null) || behind="?"
        # Only warn if actually behind — local-only commits (ahead) are not an update
        if [[ "$behind" != "0" ]]; then
            echo ""
            echo -e "${YELLOW}⚠ KyZN update available${RESET} (${behind} commits behind)"
            echo -e "  ${YELLOW}Update for better analysis accuracy and security fixes.${RESET}"
            echo -e "  Run: ${CYAN}kyzn update${RESET}"
            echo ""
        fi
    fi
}

main() {
    local cmd="${1:-}"

    # Check for updates (non-blocking, once per day) — skip for fast/local commands
    case "$cmd" in
        version|--version|-v|help|--help|-h|""|doctor|selftest) ;;
        *) check_for_updates ;;
    esac

    case "$cmd" in
        quick|improve)
            shift
            source "$KYZN_ROOT/lib/detect.sh"
            source "$KYZN_ROOT/lib/interview.sh"
            source "$KYZN_ROOT/lib/measure.sh"
            source "$KYZN_ROOT/lib/prompt.sh"
            source "$KYZN_ROOT/lib/provider.sh"
            source "$KYZN_ROOT/lib/execute.sh"
            source "$KYZN_ROOT/lib/verify.sh"
            source "$KYZN_ROOT/lib/allowlist.sh"
            source "$KYZN_ROOT/lib/report.sh"
            cmd_improve "$@"
            ;;
        fix)
            shift
            source "$KYZN_ROOT/lib/detect.sh"
            source "$KYZN_ROOT/lib/measure.sh"
            source "$KYZN_ROOT/lib/prompt.sh"
            source "$KYZN_ROOT/lib/provider.sh"
            source "$KYZN_ROOT/lib/execute.sh"
            source "$KYZN_ROOT/lib/verify.sh"
            source "$KYZN_ROOT/lib/allowlist.sh"
            source "$KYZN_ROOT/lib/report.sh"
            source "$KYZN_ROOT/lib/analyze.sh"
            cmd_analyze --fix "$@"
            ;;
        analyze)
            shift
            source "$KYZN_ROOT/lib/detect.sh"
            source "$KYZN_ROOT/lib/measure.sh"
            source "$KYZN_ROOT/lib/prompt.sh"
            source "$KYZN_ROOT/lib/provider.sh"
            source "$KYZN_ROOT/lib/execute.sh"
            source "$KYZN_ROOT/lib/verify.sh"
            source "$KYZN_ROOT/lib/allowlist.sh"
            source "$KYZN_ROOT/lib/report.sh"
            source "$KYZN_ROOT/lib/analyze.sh"
            cmd_analyze "$@"
            ;;
        measure)
            shift
            source "$KYZN_ROOT/lib/detect.sh"
            source "$KYZN_ROOT/lib/measure.sh"
            cmd_measure "$@"
            ;;
        status)
            shift
            source "$KYZN_ROOT/lib/detect.sh"
            source "$KYZN_ROOT/lib/measure.sh"
            source "$KYZN_ROOT/lib/history.sh"
            cmd_status "$@"
            ;;
        init)
            shift
            source "$KYZN_ROOT/lib/detect.sh"
            source "$KYZN_ROOT/lib/interview.sh"
            cmd_init "$@"
            ;;
        doctor)
            shift
            cmd_doctor "$@"
            ;;
        approve)
            shift
            source "$KYZN_ROOT/lib/approve.sh"
            source "$KYZN_ROOT/lib/history.sh"
            cmd_approve "$@"
            ;;
        reject)
            shift
            source "$KYZN_ROOT/lib/approve.sh"
            source "$KYZN_ROOT/lib/history.sh"
            cmd_reject "$@"
            ;;
        diff)
            shift
            source "$KYZN_ROOT/lib/history.sh"
            cmd_diff "$@"
            ;;
        history)
            shift
            source "$KYZN_ROOT/lib/history.sh"
            cmd_history "$@"
            ;;
        dashboard)
            shift
            source "$KYZN_ROOT/lib/history.sh"
            cmd_dashboard "$@"
            ;;
        schedule)
            shift
            source "$KYZN_ROOT/lib/schedule.sh"
            cmd_schedule "$@"
            ;;
        update)
            shift
            log_step "Updating KyZN..."
            if safe_git -C "$KYZN_ROOT" pull --quiet 2>/dev/null; then
                local new_ver
                new_ver=$(bash "$KYZN_ROOT/kyzn" version 2>/dev/null || echo "unknown")
                log_ok "Updated to $new_ver"
            else
                log_error "Update failed — check git status in $KYZN_ROOT"
                exit 1
            fi
            ;;
        selftest)
            shift
            bash "$KYZN_ROOT/tests/selftest.sh" "$@"
            ;;
        version|--version|-v)
            echo "KyZN v${KYZN_VERSION}"
            ;;
        help|--help|-h|"")
            usage
            ;;
        *)
            log_error "Unknown command: $cmd"
            echo ""
            usage
            exit 1
            ;;
    esac
}

# ---------------------------------------------------------------------------
# Doctor — prerequisite checker
# ---------------------------------------------------------------------------
cmd_doctor() {
    log_header "KyZN doctor — checking prerequisites"
    local ok=true

    # Required tools (core)
    local -a required=("git" "gh" "jq" "yq")
    for tool in "${required[@]}"; do
        if command -v "$tool" &>/dev/null; then
            local ver
            case "$tool" in
                git)    ver=$(git --version | awk '{print $3}') ;;
                gh)     ver=$(gh --version | head -1 | awk '{print $3}') ;;
                jq)     ver=$(jq --version 2>/dev/null || echo "unknown") ;;
                yq)     ver=$(yq --version 2>/dev/null | awk '{print $NF}') ;;
            esac
            log_ok "$tool ($ver)"
        else
            log_fail "$tool — not found"
            case "$tool" in
                git)
                    log_dim "  Install: sudo apt install git  (or brew install git)" ;;
                gh)
                    log_dim "  Install: https://cli.github.com" ;;
                jq)
                    log_dim "  Install: sudo apt install jq  (or brew install jq)" ;;
                yq)
                    log_dim "  Install: https://github.com/mikefarah/yq#install" ;;
            esac
            ok=false
        fi
    done

    # AI providers — at least one required
    echo ""
    log_info "AI providers:"
    local has_any_provider=false

    # Claude CLI
    if command -v claude &>/dev/null; then
        local claude_ver
        claude_ver=$(claude --version 2>/dev/null || echo "unknown")
        log_ok "claude ($claude_ver)"

        # Claude auth (API key OR OAuth login)
        if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
            local _key_test
            _key_test=$(claude -p "hi" --output-format json --no-session-persistence --max-turns 1 2>/dev/null) || true
            if echo "$_key_test" | grep -q '"is_error":true' 2>/dev/null; then
                log_fail "  Claude auth: API key is SET but INVALID"
                log_dim "    Fix: unset ANTHROPIC_API_KEY  (to use OAuth login instead)"
            else
                log_ok "  Claude auth: API key (verified)"
                has_any_provider=true
            fi
        elif claude auth status &>/dev/null 2>&1 || [[ -d "${HOME}/.claude" ]]; then
            log_ok "  Claude auth: logged in"
            has_any_provider=true
        else
            log_warn "  Claude not authenticated"
            log_dim "    Run 'claude' and log in, or set ANTHROPIC_API_KEY"
        fi
    else
        log_dim "claude — not installed (npm install -g @anthropic-ai/claude-code)"
    fi

    # Codex CLI
    if command -v codex &>/dev/null; then
        local codex_ver
        codex_ver=$(codex --version 2>/dev/null || echo "unknown")
        log_ok "codex ($codex_ver)"

        if [[ -n "${OPENAI_API_KEY:-}" ]]; then
            log_ok "  Codex auth: API key set"
            has_any_provider=true
        elif codex auth status &>/dev/null 2>&1; then
            log_ok "  Codex auth: logged in"
            has_any_provider=true
        else
            log_warn "  Codex not authenticated"
            log_dim "    Set OPENAI_API_KEY or run codex auth"
        fi

        # Check if Codex sandbox works (bwrap can fail on newer kernels)
        if $has_any_provider; then
            local _sandbox_test
            _sandbox_test=$(echo "Say ok" | timeout 15 codex exec --json --ephemeral --full-auto 2>/dev/null || true)
            if echo "$_sandbox_test" | grep -q "bwrap" 2>/dev/null; then
                log_warn "  Codex sandbox (bwrap) unavailable on this kernel"
                log_dim "    KyZN will auto-fallback to unsandboxed mode."
                log_dim "    KyZN's own safety layer (branch isolation, secret detection,"
                log_dim "    build gate, score gate) still applies."
            else
                log_ok "  Codex sandbox: working"
            fi
        fi
    else
        log_dim "codex — not installed (https://github.com/openai/codex)"
    fi

    if ! $has_any_provider; then
        log_fail "No authenticated AI provider found. Install and authenticate claude or codex."
        ok=false
    fi

    # Show provider resolution for auto mode
    local configured_provider
    configured_provider=$(config_get '.preferences.provider' 'claude' 2>/dev/null || echo "claude")
    if [[ "$configured_provider" == "auto" ]] && $has_any_provider; then
        # Resolve deterministically
        local resolved="(none)"
        if command -v claude &>/dev/null; then resolved="claude"
        elif command -v codex &>/dev/null; then resolved="codex"; fi
        log_info "Auto provider would resolve to: $resolved"
    fi

    # GitHub auth
    if gh auth status &>/dev/null; then
        log_ok "gh authenticated"
    else
        log_warn "gh not authenticated (run: gh auth login)"
    fi

    # Optional tools by language
    echo ""
    log_info "Optional tools (per project type):"

    local _opt_tool _opt_desc
    for _opt_tool in npm npx eslint tsc ruff mypy pytest cargo go govulncheck; do
        case "$_opt_tool" in
            npm|npx)     _opt_desc="Node.js" ;;
            eslint)      _opt_desc="Node.js linting" ;;
            tsc)         _opt_desc="TypeScript" ;;
            ruff)        _opt_desc="Python linting" ;;
            mypy)        _opt_desc="Python types" ;;
            pytest)      _opt_desc="Python testing" ;;
            cargo)       _opt_desc="Rust" ;;
            go)          _opt_desc="Go" ;;
            govulncheck) _opt_desc="Go security" ;;
        esac
        if command -v "$_opt_tool" &>/dev/null; then
            log_ok "$_opt_tool ($_opt_desc)"
        else
            log_dim "$_opt_tool ($_opt_desc) — not installed"
        fi
    done

    echo ""
    if $ok; then
        log_ok "All required tools found. KyZN is ready."
        echo ""
        echo -e "  ${DIM}Next:${RESET} Run ${CYAN}kyzn init${RESET} to set up a project, or ${CYAN}kyzn measure${RESET} to check health."
    else
        log_fail "Missing required tools. Install them and re-run kyzn doctor."
        echo -e "  ${DIM}Tip: The installer auto-installs jq and yq:${RESET}"
        echo -e "  ${CYAN}bash install.sh${RESET}  (from the KyZN repo directory)"
        exit 1
    fi
}

main "$@"
