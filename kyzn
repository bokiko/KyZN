#!/usr/bin/env bash
# kyzn — Autonomous Code Improvement CLI
# https://github.com/bokiko/kyzn
set -euo pipefail

# Require bash 4.3+ for associative arrays and namerefs
if (( BASH_VERSINFO[0] < 4 || (BASH_VERSINFO[0] == 4 && BASH_VERSINFO[1] < 3) )); then
    echo "KyZN requires bash 4.3 or later (you have $BASH_VERSION)." >&2
    if [[ "$(uname)" == "Darwin" ]]; then
        echo "  Install with: brew install bash" >&2
        echo "  Then run: /opt/homebrew/bin/bash $(readlink -f "$0" 2>/dev/null || echo "$0") $*" >&2
    fi
    exit 1
fi

KYZN_VERSION="0.4.0"
# Resolve symlinks portably (readlink -f doesn't exist on macOS)
_kyzn_resolve() {
    local f="$1"
    local max_depth=20
    local depth=0
    while [[ -L "$f" ]]; do
        (( depth++ >= max_depth )) && { echo "kyzn: symlink loop detected resolving $1" >&2; echo "$f"; return 1; }
        local dir
        dir="$(cd "$(dirname "$f")" && pwd)"
        f="$(readlink "$f")"
        [[ "$f" != /* ]] && f="$dir/$f"
    done
    echo "$f"
}
KYZN_ROOT="$(cd "$(dirname "$(_kyzn_resolve "${BASH_SOURCE[0]}")")" && pwd)"

# Load core library
# shellcheck source=lib/core.sh
source "$KYZN_ROOT/lib/core.sh"

# ---------------------------------------------------------------------------
# Subcommand routing
# ---------------------------------------------------------------------------
usage() {
    cat <<'EOF'
KyZN — Autonomous Code Improvement CLI (kaizen)

Usage:
  kyzn <command> [options]

Commands:
  improve         Run an improvement cycle (measure → improve → verify → PR)
  analyze         Deep analysis with Opus — finds real bugs, security issues, arch problems
  measure         Measure project health (no changes)
  status          Show health score dashboard
  init            Interactive setup (creates .kyzn/config.yaml)
  doctor          Check prerequisites

  approve <id>    Sign off on a completed improvement
  reject <id>     Reject with reason
  diff <id>       Show what a run changed
  history         Show all runs with scores and trends

  schedule        Set up recurring runs (cron)
  selftest        Run the test suite
  update          Pull latest version
  version         Show version

Options:
  -h, --help      Show this help
  -v, --version   Show version

Examples:
  kyzn init                       # First-time setup
  kyzn doctor                     # Check prerequisites
  kyzn improve                    # Interactive (choose model & budget)
  kyzn improve --auto             # Use saved config (for cron)
  kyzn improve --focus security   # Target specific area
  kyzn improve --mode deep        # Real improvements only
  kyzn improve --model opus       # Use specific model
  kyzn improve --budget 5.00      # Set budget per run
  kyzn improve -v                 # Show live progress
  kyzn measure                    # Measure only, no changes
EOF
}

# ---------------------------------------------------------------------------
# Update check — notify user if a newer version exists
# ---------------------------------------------------------------------------
check_for_updates() {
    # Check if install dir is a git repo
    [[ -d "$KYZN_ROOT/.git" ]] || return

    # Quick check: is local HEAD behind remote? (fetch once per day)
    local check_file="${HOME}/.kyzn/last-update-check"
    local needs_fetch=true
    mkdir -p "${HOME}/.kyzn"

    if [[ -f "$check_file" ]]; then
        local last_check now
        last_check=$(cat "$check_file" 2>/dev/null || echo 0)
        now=$(date +%s)
        (( now - last_check < 86400 )) && needs_fetch=false
    fi

    if $needs_fetch; then
        if command -v timeout &>/dev/null; then
            timeout 5 git -C "$KYZN_ROOT" fetch origin --quiet 2>/dev/null || true
        else
            git -C "$KYZN_ROOT" fetch origin --quiet 2>/dev/null || true
        fi
        date +%s > "$check_file" 2>/dev/null || true
    fi

    # Compare local vs remote
    local local_head remote_head
    local_head=$(git -C "$KYZN_ROOT" rev-parse HEAD 2>/dev/null) || return
    remote_head=$(git -C "$KYZN_ROOT" rev-parse origin/main 2>/dev/null) || return

    if [[ "$local_head" != "$remote_head" ]]; then
        local behind
        behind=$(git -C "$KYZN_ROOT" rev-list --count HEAD..origin/main 2>/dev/null) || behind="?"
        echo ""
        echo -e "${RED}✗ KyZN is outdated${RESET} (${behind} commits behind)"
        echo -e "  ${RED}Update now for better analysis accuracy and security fixes.${RESET}"
        echo -e "  Run: ${CYAN}kyzn update${RESET}"
        echo ""
    fi
}

main() {
    local cmd="${1:-}"

    # Check for updates (non-blocking, once per day) — skip for fast/local commands
    case "$cmd" in
        version|--version|-v|help|--help|-h|""|doctor|selftest) ;;
        *) check_for_updates ;;
    esac

    case "$cmd" in
        improve)
            shift
            source "$KYZN_ROOT/lib/detect.sh"
            source "$KYZN_ROOT/lib/interview.sh"
            source "$KYZN_ROOT/lib/measure.sh"
            source "$KYZN_ROOT/lib/prompt.sh"
            source "$KYZN_ROOT/lib/execute.sh"
            source "$KYZN_ROOT/lib/verify.sh"
            source "$KYZN_ROOT/lib/allowlist.sh"
            source "$KYZN_ROOT/lib/report.sh"
            cmd_improve "$@"
            ;;
        analyze)
            shift
            source "$KYZN_ROOT/lib/detect.sh"
            source "$KYZN_ROOT/lib/measure.sh"
            source "$KYZN_ROOT/lib/prompt.sh"
            source "$KYZN_ROOT/lib/execute.sh"
            source "$KYZN_ROOT/lib/verify.sh"
            source "$KYZN_ROOT/lib/allowlist.sh"
            source "$KYZN_ROOT/lib/report.sh"
            source "$KYZN_ROOT/lib/analyze.sh"
            cmd_analyze "$@"
            ;;
        measure)
            shift
            source "$KYZN_ROOT/lib/detect.sh"
            source "$KYZN_ROOT/lib/measure.sh"
            cmd_measure "$@"
            ;;
        status)
            shift
            source "$KYZN_ROOT/lib/detect.sh"
            source "$KYZN_ROOT/lib/measure.sh"
            source "$KYZN_ROOT/lib/history.sh"
            cmd_status "$@"
            ;;
        init)
            shift
            source "$KYZN_ROOT/lib/detect.sh"
            source "$KYZN_ROOT/lib/interview.sh"
            cmd_init "$@"
            ;;
        doctor)
            shift
            cmd_doctor "$@"
            ;;
        approve)
            shift
            source "$KYZN_ROOT/lib/approve.sh"
            source "$KYZN_ROOT/lib/history.sh"
            cmd_approve "$@"
            ;;
        reject)
            shift
            source "$KYZN_ROOT/lib/approve.sh"
            source "$KYZN_ROOT/lib/history.sh"
            cmd_reject "$@"
            ;;
        diff)
            shift
            source "$KYZN_ROOT/lib/history.sh"
            cmd_diff "$@"
            ;;
        history)
            shift
            source "$KYZN_ROOT/lib/history.sh"
            cmd_history "$@"
            ;;
        schedule)
            shift
            source "$KYZN_ROOT/lib/schedule.sh"
            cmd_schedule "$@"
            ;;
        update)
            shift
            log_step "Updating kyzn..."
            if git -C "$KYZN_ROOT" pull --quiet 2>/dev/null; then
                local new_ver
                new_ver=$(bash "$KYZN_ROOT/kyzn" version 2>/dev/null || echo "unknown")
                log_ok "Updated to $new_ver"
            else
                log_error "Update failed — check git status in $KYZN_ROOT"
                exit 1
            fi
            ;;
        selftest)
            shift
            bash "$KYZN_ROOT/tests/selftest.sh" "$@"
            ;;
        version|--version|-v)
            echo "KyZN v${KYZN_VERSION}"
            ;;
        help|--help|-h|"")
            usage
            ;;
        *)
            log_error "Unknown command: $cmd"
            echo ""
            usage
            exit 1
            ;;
    esac
}

# ---------------------------------------------------------------------------
# Doctor — prerequisite checker
# ---------------------------------------------------------------------------
cmd_doctor() {
    log_header "KyZN doctor — checking prerequisites"
    local ok=true

    # Required tools
    local -a required=("git" "gh" "claude" "jq" "yq")
    for tool in "${required[@]}"; do
        if command -v "$tool" &>/dev/null; then
            local ver
            case "$tool" in
                git)    ver=$(git --version | awk '{print $3}') ;;
                gh)     ver=$(gh --version | head -1 | awk '{print $3}') ;;
                claude) ver=$(claude --version 2>/dev/null || echo "unknown") ;;
                jq)     ver=$(jq --version 2>/dev/null || echo "unknown") ;;
                yq)     ver=$(yq --version 2>/dev/null | awk '{print $NF}') ;;
            esac
            log_ok "$tool ($ver)"
        else
            log_fail "$tool — not found"
            case "$tool" in
                git)
                    log_dim "  Install: sudo apt install git  (or brew install git)" ;;
                gh)
                    log_dim "  Install: https://cli.github.com" ;;
                claude)
                    log_dim "  Install: npm install -g @anthropic-ai/claude-code" ;;
                jq)
                    log_dim "  Install: sudo apt install jq  (or brew install jq)" ;;
                yq)
                    log_dim "  Install: https://github.com/mikefarah/yq#install" ;;
            esac
            ok=false
        fi
    done

    # Claude auth (API key OR OAuth login)
    if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
        log_ok "Claude auth: API key"
    elif claude auth status &>/dev/null 2>&1 || [[ -d "${HOME}/.claude" ]]; then
        log_ok "Claude auth: logged in (no API key needed)"
    else
        log_warn "Claude not authenticated. Either:"
        log_dim "  • Run 'claude' and log in via browser (recommended)"
        log_dim "  • Or set ANTHROPIC_API_KEY environment variable"
    fi

    # GitHub auth
    if gh auth status &>/dev/null; then
        log_ok "gh authenticated"
    else
        log_warn "gh not authenticated (run: gh auth login)"
    fi

    # Optional tools by language
    echo ""
    log_info "Optional tools (per project type):"

    local _opt_tool _opt_desc
    for _opt_tool in npm npx eslint tsc ruff mypy pytest cargo go govulncheck; do
        case "$_opt_tool" in
            npm|npx)     _opt_desc="Node.js" ;;
            eslint)      _opt_desc="Node.js linting" ;;
            tsc)         _opt_desc="TypeScript" ;;
            ruff)        _opt_desc="Python linting" ;;
            mypy)        _opt_desc="Python types" ;;
            pytest)      _opt_desc="Python testing" ;;
            cargo)       _opt_desc="Rust" ;;
            go)          _opt_desc="Go" ;;
            govulncheck) _opt_desc="Go security" ;;
        esac
        if command -v "$_opt_tool" &>/dev/null; then
            log_ok "$_opt_tool ($_opt_desc)"
        else
            log_dim "$_opt_tool ($_opt_desc) — not installed"
        fi
    done

    echo ""
    if $ok; then
        log_ok "All required tools found. KyZN is ready."
        echo ""
        echo -e "  ${DIM}Next:${RESET} Run ${CYAN}kyzn init${RESET} to set up a project, or ${CYAN}kyzn measure${RESET} to check health."
    else
        log_fail "Missing required tools. Install them and re-run kyzn doctor."
        echo -e "  ${DIM}Tip: The installer auto-installs jq and yq:${RESET}"
        echo -e "  ${CYAN}bash install.sh${RESET}  (from the KyZN repo directory)"
        exit 1
    fi
}

main "$@"
